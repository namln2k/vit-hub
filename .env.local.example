# Local Supabase profile
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=replace-with-supabase-status-publishable-key
SUPABASE_INTERNAL_URL=http://host.docker.internal:54321
SUPABASE_SERVICE_ROLE_KEY=replace-with-supabase-status-secret-key

# Optional local Google OAuth / One Tap
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_SECRET=
NEXT_PUBLIC_GOOGLE_ONE_TAP_ENABLED=false
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=vit-hub
R2_PUBLIC_BASE_URL=
R2_FREE_TIER_MAX_UPLOAD_BYTES=1048576
R2_POST_IMAGE_MAX_UPLOAD_BYTES=5242880
