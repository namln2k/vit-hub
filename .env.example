# Supabase - browser client
# Vite exposes only VITE_* variables to the browser. These values are public by design.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-key

# Supabase - server API routes
# Used by /api/* server API routes. In local development these can match the
# VITE_SUPABASE_* values above, but configure them as server-only variables in hosting.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-key
# Secret. Never expose this with VITE_ or NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Cloudflare R2 - server API routes
# Keep credentials server-only. Do not add the VITE_ or NEXT_PUBLIC_ prefix.
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=vit-hub
# Public origin used to build avatar URLs. This is not a credential.
R2_PUBLIC_BASE_URL=https://your-public-r2-domain.example.com
R2_FREE_TIER_MAX_UPLOAD_BYTES=1048576
