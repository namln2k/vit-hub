# Production credential profile. Copy to .env.
# The same public URL/key are used by the browser and the Next.js server.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional Google One Tap
NEXT_PUBLIC_GOOGLE_ONE_TAP_ENABLED=false
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# Cloudflare R2 - server only
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=vit-hub
R2_PUBLIC_BASE_URL=https://your-public-r2-domain.example.com
R2_FREE_TIER_MAX_UPLOAD_BYTES=1048576
R2_POST_IMAGE_MAX_UPLOAD_BYTES=5242880
